# Google / Imagen + chat (read by genblaze-google)
GEMINI_API_KEY=

# ElevenLabs TTS (genblaze-elevenlabs)
ELEVEN_API_KEY=

# AssemblyAI STT — only for bring-your-own-voice (genblaze-assemblyai; free $50 credit)
ASSEMBLYAI_API_KEY=

# Backblaze B2 (read by genblaze-s3) - same vars proven in the WSL spike
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=ghostreel-assets
B2_REGION=eu-central-003

# Rate gate — set ACCESS_CODE to require it on generation endpoints (leave blank = open)
ACCESS_CODE=
DAILY_JOB_LIMIT=50

# Optional overrides
IMAGE_MODEL=imagen-4.0-generate-001
CHAT_MODEL=gemini-2.5-flash
TTS_MODEL=eleven_v3
VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ASSET_PREFIX=ghostreel
